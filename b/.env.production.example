# ---------------------------------------------------------------------------
# PRODUCTION backend environment. Copy to `.env` on the server and fill in.
#   cp .env.production.example .env  &&  edit .env
# Never commit the real `.env`.
# ---------------------------------------------------------------------------

# --- Django core ---
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=CHANGE_ME__run: python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_ALLOWED_HOSTS=brain.your-domain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

# Turn these on only AFTER HTTPS is confirmed working end-to-end:
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_HSTS_SECONDS=0

# --- Database (matches the db service in docker-compose.prod.yml) ---
POSTGRES_DB=brain
POSTGRES_USER=brain
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery (service names from docker-compose.prod.yml) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AI provider (OpenAI, or an OpenAI-compatible endpoint) ---
# OpenAI:  leave OPENAI_BASE_URL empty, models below are OpenAI's.
# Gemini:  OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#          OPENAI_CHAT_MODEL=gemini-2.5-flash  OPENAI_EMBEDDING_MODEL=text-embedding-004
#          (NOTE: Gemini embeddings are 768-dim; the Resume/Position vector
#           columns are 1536-dim — change them if you use Gemini for embeddings.)
OPENAI_API_KEY=CHANGE_ME_or_leave_blank_to_disable_AI
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-2024-08-06
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Initial admin (created on first deploy; leave blank to skip) ---
DJANGO_SUPERUSER_EMAIL=you@your-domain.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_strong_admin_password

# --- Email (SMTP) ---
DEFAULT_FROM_EMAIL=you@your-domain.com
FRONTEND_URL=https://your-frontend-domain.com
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@your-domain.com
EMAIL_HOST_PASSWORD=CHANGE_ME_email_app_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

DEFAULT_LANGUAGE=fr
